# ─────────────────────────────────────────────────────────────
# TrafficGuard — Backend environment variables
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (Atlas or local)
# Example (Atlas):  mongodb+srv://<user>:<password>@cluster.mongodb.net/trafficguard
# Example (local):  mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017

# JWT secret key — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_long_random_secret

# Optional overrides (defaults shown)
# CAMERA_UPDATE_INTERVAL=5   # seconds between frame grabs
# CAMERA_TIMEOUT=5           # HTTP timeout for camera fetch
# CONFIDENCE_THRESHOLD=0.25  # YOLO detection confidence cutoff
